# 当前使用的模型提供商: "deepseek" 或 "mimo"
LLM_PROVIDER=mimo

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# 其他国内模型示例：
# 通义千问:
# DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DEEPSEEK_MODEL=qwen-plus

# 文心一言需要不同的 SDK，暂不支持

MIMO_API_KEY=sk-your-key-here
MIMO_BASE_URL=https://api.xiaomimimo.com
MIMO_MODEL=mimo-v2.5-pro

# 盈米且慢 MCP API Key（基金数据分析）
YINGMI_API_KEY=

# ── 仲裁 Agent 配置（高级推理模型，如 DeepSeek R1）──
# 配置后，复杂投资决策会由仲裁 Agent 做最终裁决
ARBITRATION_API_KEY=sk-your-key-here
ARBITRATION_BASE_URL=https://api.deepseek.com
ARBITRATION_MODEL=deepseek-v4-pro

# ── 调仓分析配置 ──
# 资产类型基础配比（JSON 格式，键为类别，值为比例，总和建议为 1）
# REBALANCE_BASE_ALLOCATION='{"equity":0.40,"bond":0.30,"money":0.05,"hybrid":0.10,"index":0.10,"qdii":0.05}'

# 估值调整系数（JSON，键为估值水平标签，值为调整倍数）
# REBALANCE_VALUATION_ADJUSTMENT='{"极度低估":1.4,"低估":1.2,"合理":1.0,"偏高":0.8,"极度高估":0.6}'

# 估值百分位分界线（逗号分隔：极度低估上限,低估上限,合理上限,偏高上限）
# REBALANCE_VALUATION_PERCENTILES=20,30,70,80

# 偏离度阈值（逗号分隔：平衡上限,轻微上限）
# REBALANCE_DRIFT_THRESHOLDS=0.03,0.08

# 现金目标比例（逗号分隔：低估时,合理时,高估时）
# REBALANCE_CASH_TARGETS=0.05,0.10,0.15

# 现金建议触发偏移（逗号分隔：超配偏移,欠配偏移）
# REBALANCE_CASH_TRIGGERS=0.05,0.02

# 资产类别偏离忽略阈值（低于此值不生成建议）
# REBALANCE_DRIFT_IGNORE=0.05

# 低估指数建议数量上限
# REBALANCE_UNDERVALUE_MAX=2

# 低估指数建议金额范围（逗号分隔：最小,最大）
# REBALANCE_UNDERVALUE_AMOUNT=1000,3000

# 7日年化收益率（用于零钱账户计息）
# CASH_ANNUAL_YIELD_7D=0.01512